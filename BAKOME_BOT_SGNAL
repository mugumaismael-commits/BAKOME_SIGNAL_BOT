  // Actualités
  if (/(news|actualités|actu|infos)/i.test(lower)) {
    return `📰 Pour les actualités, utilise:\n\n` +
      `!news trading – ForexFactory, Bloomberg\n` +
      `!news tech – TechCrunch, Wired\n` +
      `!news programming – Dev.to, StackOverflow`;
  }

  // To-do
  if (/(todo|tâche|rappel|liste)/i.test(lower)) {
    return `📝 Pour gérer tes tâches:\n\n` +
