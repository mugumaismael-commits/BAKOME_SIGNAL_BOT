// ================= INTERFACE SIGNAL VIA SIGNAL-CLI =================
async function sendSignalMessage(recipient, message) {
  const escapedMessage = message.replace(/"/g, '\\"').replace(/\n/g, '\\n');
  const command = `signal-cli -u "${SIGNAL_NUMBER}" send -m "${escapedMessage}" "${recipient}"`;
  
  try {
    await execPromise(command);
    console.log(`✅ Message envoyé à ${recipient}`);
  } catch (error) {
    console.error(`❌ Erreur envoi à ${recipient}:`, error.message);
  }
}

async function receiveSignalMessages() {
  try {
    const { stdout } = await execPromise(`signal-cli -u "${SIGNAL_NUMBER}" receive --timeout=2`);
    const lines = stdout.split('\n');
    
    let currentMessage = null;
    let currentSender = null;
    
    for (const line of lines) {
      if (line.startsWith('Envelope from:')) {
        currentSender = line.split('Envelope from:')[1].trim();
      }
      if (line.startsWith('Message:')) {
        currentMessage = line.substring('Message:'.length).trim();
      }
      if (currentSender && currentMessage && !currentMessage.startsWith('!response')) {
        await processIncomingMessage(currentSender, currentMessage);
        currentSender = null;
        currentMessage = null;
      }
    }
  } catch (error) {
    // Pas de nouveau message, c'est normal
  }
}

async function processIncomingMessage(sender, text) {
  console.log(`📩 Message de ${sender}: ${text.substring(0, 50)}...`);
  
  // Enregistrer l'utilisateur
  createOrUpdateUser(sender, sender.split('@')[0]);
  addMessage(sender, "user", text);
  
  // Détection anti-arnaque
  const threat = detectThreat(text);
  if (threat.threat) {
    updateRiskScore(sender, 2);
    const alertMsg = `⚠️ *ALERTE SÉCURITÉ ${BOT_NAME}*\n\n` +
      `Motif suspect détecté: "${threat.pattern}"\n` +
      `Score de risque augmenté.\n\n` +
      `⚠️ Ne partage jamais tes informations personnelles.`;
    await sendSignalMessage(sender, alertMsg);
    addMessage(sender, "bot", alertMsg);
    return;
  }
  
  let response = null;
  
  // Vérifier si c'est une commande
  if (text.startsWith(PREFIX)) {
    const parts = text.slice(PREFIX.length).trim().split(/ +/);
    const command = parts[0].toLowerCase();
    const args = parts.slice(1);
    const cmdResult = await handleCommand(sender, command, args);
    if (cmdResult) response = cmdResult;
  }
  
  // Si pas de commande ou commande non reconnue, générer réponse intelligente
  if (!response) {
    const history = await getHistory(sender, 5);
    response = await generateResponse(text, sender, history);
  }
  
  // Envoyer la réponse
  await sendSignalMessage(sender, response);
  addMessage(sender, "bot", response.substring(0, 500));
}

