      return `📰 *Actualités*\nCatégories: trading, tech, programming\nExemple: !news trading`;
    }
    return `📰 *Actualités ${cat}*\n\nSources: ${categories[cat]}\n\n💡 Pour plus de détails, utilise un navigateur.`;
  }

