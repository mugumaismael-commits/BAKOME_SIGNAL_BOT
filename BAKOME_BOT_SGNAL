      return `💰 *Prix Cryptos*\nBTC: $${parseFloat(btc.price).toLocaleString()}\nETH: $${parseFloat(eth.price).toLocaleString()}\n\n_Source: Binance_`;
    } catch (error) {
      return `💰 BTC: ~$65,000 | ETH: ~$3,200 (estimation)`;
    }
  }

