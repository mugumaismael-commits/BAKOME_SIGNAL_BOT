// ================= ANTI-ARNAQUE =================
const scamPatterns = [
  "hack", "crack", "phish", "malware", "ransom", "virus",
  "send me", "wallet seed", "bitcoin giveaway", "free money",
  "double your", "investment opportunity", "urgent transfer",
  "password", "login", "credit card", "ssn", "social security"
];

function detectThreat(text) {
  const lower = text.toLowerCase();
  for (let p of scamPatterns) {
    if (lower.includes(p)) return { threat: true, pattern: p };
  }
  return { threat: false };
}

// ================= FONCTIONS MÉMOIRE =================
function addMessage(userId, role, content) {
  db.run("INSERT INTO conversations (user_id, role, content, timestamp) VALUES (?,?,?,?)",
    [userId, role, content, moment().format()]);
}

function getHistory(userId, limit = 5) {
  return new Promise((resolve) => {
    db.all("SELECT role, content FROM conversations WHERE user_id = ? ORDER BY timestamp DESC LIMIT ?",
      [userId, limit], (err, rows) => {
        resolve(rows ? rows.reverse() : []);
      });
  });
}

function createOrUpdateUser(userId, name) {
  db.get("SELECT * FROM users WHERE user_id = ?", [userId], (err, row) => {
    if (!row) {
      db.run("INSERT INTO users (user_id, name, first_seen, last_seen) VALUES (?,?,?,?)",
        [userId, name, moment().format(), moment().format()]);
    } else {
      db.run("UPDATE users SET last_seen = ? WHERE user_id = ?", [moment().format(), userId]);
    }
  });
}

function updateRiskScore(userId, points) {
  db.run("UPDATE users SET risk = risk + ? WHERE user_id = ?", [points, userId]);
}

