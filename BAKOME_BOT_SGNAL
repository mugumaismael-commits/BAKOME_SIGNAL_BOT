  // Détection de langue approximative
  let detectedLang = "en";
  if (/[êéèëçàùîïû]/i.test(text)) detectedLang = "fr";
  else if (/[你你好]/i.test(text)) detectedLang = "zh";
  else if (/[こんにちは]/i.test(text)) detectedLang = "ja";
  else if (/[안녕]/i.test(text)) detectedLang = "ko";
  else if (/[مرحبا]/i.test(text)) detectedLang = "ar";

  // Salutations
  if (lower.match(/^(bonjour|salut|hello|hi|hey|coucou|bonsoir|bjr)$/i)) {
    return `👋 Bonjour ! Je suis ${BOT_NAME}, ton assistant IA sur Signal.\n\n` +
      `Je peux t'aider avec:\n` +
      `• Trading (MQL5, XAUUSD, crypto)\n` +
      `• Programmation (Python, JS, C++)\n` +
      `• Météo, actualités, sport\n` +
      `• To-do list, rappels\n\n` +
      `👉 Envoie !help pour voir toutes les commandes.`;
  }

  // Remerciements
  if (lower.match(/merci|thanks|thank you|thx/i)) {
    return `🙏 Avec plaisir ! Je suis là pour t'aider 24h/24.\n\n` +
      `N'hésite pas si tu as d'autres questions. Bonne journée ! ☀️`;
