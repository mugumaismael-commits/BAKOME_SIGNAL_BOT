    return `⚽ *Résultats sportifs*\n\nUtilise TheSportsDB (API gratuite) pour les scores en direct.\n\nCommandes: !sport football, !sport basketball`;
  }

  if (cmd === "time") {
    const tz = args.join(" ") || "Europe/London";
    const timezones = {
      "paris": "Europe/Paris", "london": "Europe/London", "ny": "America/New_York",
      "tokyo": "Asia/Tokyo", "goma": "Africa/Lubumbashi", "kinshasa": "Africa/Kinshasa"
    };
    const zone = timezones[tz.toLowerCase()] || tz;
    try {
      const res = await axios.get(`http://worldtimeapi.org/api/timezone/${zone}`);
      const dt = new Date(res.data.datetime);
      return `🕐 *Heure mondiale*\n📍 ${zone}\nHeure: ${dt.toLocaleTimeString()}\nDate: ${dt.toLocaleDateString()}`;
    } catch {
      return `🕐 Fuseau "${tz}" non trouvé.\nExemples: !time Paris, !time Tokyo, !time Goma`;
    }
  }

  if (cmd === "todo") {
    const task = args.join(" ");
    if (!task) return `📝 *Ajouter une tâche*\nUtilisation: !todo Apprendre Python\n\nVoir tâches: !todos\nTerminer: !done ID`;
    
    return new Promise((resolve) => {
      db.run("INSERT INTO todos (user_id, task, created) VALUES (?,?,?)", [sender, task, moment().format()], function(err) {
        if (err) resolve(`❌ Erreur: impossible d'ajouter la tâche.`);
        else resolve(`✅ Tâche ajoutée avec succès !\n\n📝 "${task}"\nID: ${this.lastID}\n\nUtilise !done ${this.lastID} quand terminée.`);
      });
    });
  }

  if (cmd === "todos") {
    return new Promise((resolve) => {
      db.all("SELECT id, task, created FROM todos WHERE user_id = ? AND done = 0 ORDER BY created DESC", [sender], (err, rows) => {
        if (!rows || rows.length === 0) {
          resolve(`📝 *Aucune tâche en attente*\n\nAjoute-en une avec !todo [tâche]`);
        } else {
          const list = rows.map(r => `\`${r.id}\` – ${r.task} (${moment(r.created).format('DD/MM')})`).join("\n");
          resolve(`📝 *Mes tâches (${rows.length})*\n\n${list}\n\n✅ Terminer: !done ID`);
