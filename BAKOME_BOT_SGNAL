      });
    });
  }

  if (cmd === "done") {
    const id = parseInt(args[0]);
    if (!id || isNaN(id)) return `📝 *Terminer une tâche*\nUtilisation: !done 1 (où 1 est l'ID de la tâche)\n\nVoir IDs avec !todos`;
    
    return new Promise((resolve) => {
      db.run("UPDATE todos SET done = 1 WHERE id = ? AND user_id = ?", [id, sender], function(err) {
        if (err || this.changes === 0) resolve(`❌ Tâche #${id} non trouvée ou déjà terminée.`);
        else resolve(`✅ Tâche #${id} terminée ! Félicitations 🎉`);
      });
    });
  }

  if (cmd === "langues") {
    const list = Object.entries(languages).slice(0, 25).map(([k, v]) => `• ${v} (\`${k}\`)`).join("\n");
    return `🌍 *Langues supportées (${Object.keys(languages).length}+)*\n\n${list}\n\n_Je détecte automatiquement ta langue !_`;
  }

  if (cmd === "info") {
    return new Promise((resolve) => {
      db.get("SELECT risk, first_seen FROM users WHERE user_id = ?", [sender], (err, row) => {
        const risk = row?.risk || 0;
        const riskLevel = risk === 0 ? "🟢 Aucun" : risk < 5 ? "🟡 Faible" : "🔴 Élevé";
        resolve(`🤖 *${BOT_NAME} v1.0*\n\n` +
          `📊 *Statistiques:*\n` +
          `• Score de risque: ${risk} (${riskLevel})\n` +
          `• Premier contact: ${row?.first_seen ? moment(row.first_seen).format('DD/MM/YYYY') : 'Aujourd'hui'}\n` +
          `• Mémoire active: ✅\n` +
          `• Protection anti-arnaque: ✅\n` +
          `• Langues supportées: ${Object.keys(languages).length}\n` +
          `• Mode trading: MQL5 / ICT / XAUUSD\n\n` +
          `💡 Utilise !help pour plus de commandes`);
      });
    });
  }

  if (cmd === "session") {
    const token = Math.random().toString(36).substring(2, 18) + Math.random().toString(36).substring(2, 6);
    const expires = moment().add(7, 'days').format();
    db.run("INSERT OR REPLACE INTO sessions (user_id, token, expires) VALUES (?,?,?)", [sender, token, expires]);
    return `🔐 *Session sécurisée créée !*\n\n` +
      `Token: \`${token}\`\n` +
      `Expiration: ${moment(expires).format('DD/MM/YYYY HH:mm')}\n\n` +
      `⚠️ Garde ce token précieusement. Il expire dans 7 jours.`;
  }

  return null;
}

// ================= GÉNÉRATION RÉPONSE INTELLIGENTE =================
async function generateResponse(text, sender, history) {
