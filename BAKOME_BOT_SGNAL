    try {
      const res = await axios.get('https://api.exchangerate-api.com/v4/latest/USD');
      const eur = res.data.rates.EUR;
      const gbp = res.data.rates.GBP;
      const jpy = res.data.rates.JPY;
      return `💱 *Taux Forex*\nEUR/USD: ${(1/eur).toFixed(4)}\nGBP/USD: ${(1/gbp).toFixed(4)}\nUSD/JPY: ${jpy.toFixed(2)}`;
    } catch {
      return `💱 EUR/USD: ~1.08 | GBP/USD: ~1.25 | USD/JPY: ~150`;
    }
  }

  if (cmd === "meteo") {
    const city = args.join(" ");
    if (!city) return `🌤️ *Météo*\nUtilisation: !meteo Kinshasa\n\nExemples: !meteo Paris, !meteo New York, !meteo Tokyo`;
    
    try {
      const geoRes = await axios.get(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1`);
      if (!geoRes.data.results || geoRes.data.results.length === 0) {
        return `🌤️ Ville "${city}" non trouvée. Essaie avec un nom plus précis.`;
      }
      const { latitude, latitude: lat, longitude: lon, name } = geoRes.data.results[0];
      const weatherRes = await axios.get(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
      const w = weatherRes.data.current_weather;
      return `🌤️ *Météo pour ${name}*\nTempérature: ${w.temperature}°C\nVent: ${w.windspeed} km/h\nCode: ${w.weathercode}`;
    } catch {
      return `🌤️ Service météo temporairement indisponible. Réessaie plus tard.`;
    }
